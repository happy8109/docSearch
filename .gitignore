# 依赖库
node_modules/

# 本地运行生成的数据库文件（避免把真实数据提交到 Git）
db/doc_search.db
db/doc_search.db-wal
db/doc_search.db-shm
# 或者如果 db 目录下只有数据库文件，也可以直接忽略整个 db/ 目录：
# db/

# 本地的测试文档和数据存放目录
data/

# 运行日志
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 环境变量 (如果后续增加的话)
.env
.env.test
.env.production

# 操作系统自动生成的文件
.DS_Store
Thumbs.db

# 临时文件
tmp/
coverage/
.nyc_output/
